{
  "name": "@skywize-gmbh/backstage-plugin-homepage-visit-tracker-widget",
  "version": "0.1.2",
  "description": "Backstage frontend plugin: \"Top Visited\" and \"Recently Visited\" homepage widgets plus a shared, extensible \"Local data\" settings tab. Supports both the classic and the New Frontend System.",
  "keywords": [
    "backstage",
    "backstage-plugin",
    "homepage",
    "visited",
    "recently-visited"
  ],
  "license": "Apache-2.0",
  "author": "SkyWize",
  "homepage": "https://github.com/skywize-gmbh/backstage-plugin-homepage-visit-tracker-widget#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/skywize-gmbh/backstage-plugin-homepage-visit-tracker-widget.git"
  },
  "bugs": {
    "url": "https://github.com/skywize-gmbh/backstage-plugin-homepage-visit-tracker-widget/issues"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./alpha": "./src/alpha.tsx",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "alpha": [
        "src/alpha.tsx"
      ],
      "package.json": [
        "package.json"
      ]
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "module": "dist/index.esm.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.esm.js",
        "default": "./dist/index.esm.js"
      },
      "./alpha": {
        "types": "./dist/alpha.d.ts",
        "import": "./dist/alpha.esm.js",
        "default": "./dist/alpha.esm.js"
      },
      "./package.json": "./package.json"
    }
  },
  "backstage": {
    "role": "frontend-plugin",
    "pluginId": "visited",
    "pluginPackage": "@skywize-gmbh/backstage-plugin-homepage-visit-tracker-widget",
    "pluginPackages": [
      "@skywize-gmbh/backstage-plugin-homepage-visit-tracker-widget"
    ]
  },
  "sideEffects": [
    "**/registerVisitedReset.*",
    "dist/**"
  ],
  "scripts": {
    "start": "backstage-cli package start",
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack"
  },
  "dependencies": {
    "@backstage/catalog-model": "^1.8.0",
    "@backstage/core-components": "^0.18.9",
    "@backstage/core-plugin-api": "^1.12.5",
    "@backstage/frontend-plugin-api": "^0.16.2 || ^0.17.2",
    "@backstage/plugin-catalog-react": "^2.1.4 || ^3.1.0",
    "@backstage/plugin-home-react": "^0.1.37",
    "@material-ui/core": "^4.12.2"
  },
  "peerDependencies": {
    "react": "^16.13.1 || ^17.0.0 || ^18.0.0",
    "react-dom": "^16.13.1 || ^17.0.0 || ^18.0.0",
    "react-router-dom": "^6.0.0"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.1",
    "@backstage/test-utils": "^1.7.17",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/react": "^18.0.0"
  },
  "files": [
    "dist"
  ]
}
